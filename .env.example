# ======================================
# 本地开发环境配置
# ======================================
# 本文件由 dev 启动流程加载，提供给 Prisma / Rust 后端 / 开发数据库容器

# 数据库连接（Prisma CLI / Rust 后端 共用）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rs_fullstack_db

# 数据库容器参数（docker/docker-compose.dev.yml 使用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rs_fullstack_db

# 开发数据库端口（映射到宿主机）
DB_PORT=5432

# ======================================
# 数据目录（所有本地数据的根路径）
# ======================================
# 子目录自动派生：postgres / storage
DATA_LOCAL_PATH=.data

# ======================================
# 可选：单工作空间模式覆盖
# ======================================
# 设置后将覆盖数据库中的设置，并完全隐藏管理后台中的切换选项
# 值：true | false（不设置时使用数据库中的值）
# SINGLE_WORKSPACE_MODE_OVERRIDE=true
