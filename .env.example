# ======================================
# 本地开发环境配置
# ======================================
# 本文件由 dev 启动流程加载，提供给 Prisma / Server / Docker Dev 容器

# ------------------------------------------------------------------------------
# 数据库连接（Prisma CLI / Server 共用）
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apps_db

# 数据库容器参数（docker/docker-compose.dev.yml 使用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=apps_db

# ------------------------------------------------------------------------------
# 端口配置（开发环境）
# ------------------------------------------------------------------------------
# 修改以下端口号即可让整个开发栈使用不同端口，避免多项目冲突。
# SERVER_PORT → 后端 API 监听端口（Vite proxy 和 CORS 自动跟随）
# WEB_PORT    → Vite 前端开发服务器端口
# DB_PORT     → 数据库宿主机映射端口（需同步修改 DATABASE_URL 中的端口）

SERVER_PORT=4000
WEB_PORT=5173
DB_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ------------------------------------------------------------------------------
# 服务端 (packages/server)
# ------------------------------------------------------------------------------
NODE_ENV=development

# CORS 来源（留空则自动从 WEB_PORT 推导）
# 生产环境请改为实际前端域名，例如 https://app.example.com
# CORS_ORIGIN=http://localhost:5173

# ------------------------------------------------------------------------------
# 对象存储 — S3 兼容（AWS S3 / MinIO / 阿里云 OSS）
# 以下默认值对应 docker-compose 启动的本地 MinIO 实例
# ------------------------------------------------------------------------------
STORAGE_PROVIDER=s3

# 留空则使用 AWS 默认 endpoint；MinIO 或其他提供商需要明确指定
STORAGE_ENDPOINT=http://localhost:9000

STORAGE_REGION=us-east-1
STORAGE_BUCKET=avatars
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin

# 浏览器可直接访问的存储公共 URL（生产环境改为 CDN 或 OSS 公共域名）
STORAGE_PUBLIC_URL=http://localhost:9000

# true = Path-style URL（MinIO 必须）；false = Virtual-hosted style（AWS S3、OSS）
STORAGE_PATH_STYLE=true

# Docker Compose 中 MinIO 容器的 root 凭证
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=avatars

# ======================================
# 数据目录（所有本地数据的根路径）
# ======================================
# 子目录自动派生：postgres / redis / minio
DATA_LOCAL_PATH=.data

# ------------------------------------------------------------------------------
# 前端 (packages/web) — 所有客户端变量必须以 VITE_ 开头
# ------------------------------------------------------------------------------
# 浏览器侧的 tRPC 端点地址；生产环境改为 https://api.example.com/trpc
VITE_TRPC_URL=/trpc
