# ======================================
# 本地开发环境配置
# ======================================
# 本文件由 dev 启动流程加载，提供给 Prisma CLI / Rust 后端 / 开发数据库容器
# 首次使用前请复制为 .env 并根据需要修改：
#   cp .env.example .env

# ------------------------------------------------------------------------------
# 数据库连接（Prisma CLI / Rust 后端 共用）
# ------------------------------------------------------------------------------
# 端口号应与下方 DB_PORT 一致
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rs_fullstack_db

# ------------------------------------------------------------------------------
# 数据库容器参数（docker/docker-compose.dev.yml 使用）
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rs_fullstack_db

# ------------------------------------------------------------------------------
# 端口配置（开发环境）
# ------------------------------------------------------------------------------
# 开发数据库端口（映射到宿主机，避免与生产数据库冲突）
DB_PORT=5432

# Vite 前端开发服务器端口
WEB_PORT=5173

# Rust 后端端口（Vite 代理目标）
SERVER_PORT=5678

# ------------------------------------------------------------------------------
# 数据目录（所有本地数据的根路径）
# ------------------------------------------------------------------------------
# 子目录自动派生：postgres（数据库文件）/ storage（上传文件）
DATA_LOCAL_PATH=.data

# ------------------------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------------------------

# 单一工作空间模式覆盖
# 设置后将覆盖数据库中的设置，并在管理后台完全隐藏此选项
# 可选值: true | false（不设置则使用数据库中的值）
# SINGLE_WORKSPACE_MODE_OVERRIDE=true

# Docker Compose 文件列表（可选，仅在本地需要叠加多个 compose 文件时使用）
# COMPOSE_FILE=docker-compose.yml:docker-compose.debug.yml
