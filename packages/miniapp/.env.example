# 小程序 API 地址（开发时指向本地 server）
TARO_APP_API_URL=http://localhost:4000

# 对象存储基础 URL（用于拼接文件访问地址）
# MinIO 示例：
# TARO_APP_STORAGE_BASE_URL=http://localhost:9000/acme
# 腾讯 COS 示例：
# TARO_APP_STORAGE_BASE_URL=https://your_bucket.cos.ap-nanjing.myqcloud.com
TARO_APP_STORAGE_BASE_URL=http://localhost:9000/acme

# WSL2 下解决微信开发者工具无法自动刷新的问题：
# 填写 Windows 侧的绝对路径（WSL2 挂载格式），dev 启动时会将 dist 软链接到此路径
# 然后在 DevTools 里导入对应的 Windows 路径（如 C:\miniapp-dist）
# MINIAPP_WIN_OUTPUT=/mnt/c/miniapp-dist
