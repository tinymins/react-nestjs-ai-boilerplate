{
  "name": "apps",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter @acme/web",
    "dev:server": "turbo run dev --filter @acme/server",
    "dev:miniapp": "turbo run dev --filter @acme/miniapp",
    "build": "turbo run build --filter @acme/server --filter @acme/web",
    "build:miniapp": "turbo run build --filter @acme/miniapp",
    "lint": "biome check .",
    "format": "biome format . --write",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint && pnpm typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm -C packages/server db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "turbo": "2.8.17"
  }
}
